NODE_ENV=production
APP_ENV=production
PORT=5000
API_PREFIX=/api/v1
FRONTEND_URL=http://yourdomain.com

MONGO_INITDB_ROOT_USERNAME=arbitrum_admin
MONGO_INITDB_ROOT_PASSWORD=replace_with_a_long_random_mongodb_password
MONGODB_URI=mongodb://arbitrum_admin:replace_with_a_long_random_mongodb_password@mongo:27017/arbitrum?authSource=admin

REDIS_ENABLED=true
REDIS_PASSWORD=replace_with_a_long_random_redis_password
REDIS_URL=redis://:replace_with_a_long_random_redis_password@redis:6379
CACHE_KEY_PREFIX=arbitrum
BACKUP_INTERVAL_SECONDS=86400
BACKUP_RETENTION_DAYS=10
LOG_TO_FILE=true
LOG_DIR=logs
LOG_MAX_SIZE_BYTES=10485760
LOG_MAX_FILES=10

JWT_ACCESS_SECRET=replace_with_64_plus_random_characters_access_secret
JWT_REFRESH_SECRET=replace_with_64_plus_random_characters_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

ACCESS_TOKEN_COOKIE_NAME=arbitrum_access_token
REFRESH_TOKEN_COOKIE_NAME=arbitrum_refresh_token
COOKIE_SAME_SITE=lax
COOKIE_SECURE=false

PAYMENT_WALLET_ENCRYPTION_KEY=replace_with_64_plus_random_characters_wallet_key
PAYMENT_INTENT_EXPIRES_MINUTES=60

BSC_PRIMARY_RPC_URL=https://bsc-dataseed.binance.org/
BSC_BACKUP_RPC_URL=https://bsc.publicnode.com

# Leave blank to disable automatic on-chain withdrawals until the hot wallet is ready.
WITHDRAWAL_ADMIN_PRIVATE_KEY=

API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=300
API_ACTIVITY_TRACKING_ENABLED=true
API_ACTIVITY_RETENTION_DAYS=30
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=30
AUTH_IDENTIFIER_RATE_LIMIT_WINDOW_MS=900000
AUTH_IDENTIFIER_RATE_LIMIT_MAX=10
OTP_RATE_LIMIT_WINDOW_MS=600000
OTP_RATE_LIMIT_MAX=6
REFRESH_RATE_LIMIT_WINDOW_MS=60000
REFRESH_RATE_LIMIT_MAX=120
FINANCIAL_RATE_LIMIT_WINDOW_MS=60000
FINANCIAL_RATE_LIMIT_MAX=30

# Email delivery
EMAIL_ENABLED=true
EMAIL_QUEUE_ENABLED=true
EMAIL_QUEUE_CONCURRENCY=5
SMTP_HOST=smtp.yourmailprovider.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
EMAIL_FROM=no-reply@yourdomain.com
EMAIL_FROM_NAME=Arbitrum
