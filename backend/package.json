{
  "name": "arbitrum-backend",
  "version": "0.1.0",
  "private": true,
  "description": "ARBITRUM backend API built with Node.js, Express, TypeScript, and MongoDB.",
  "main": "dist/server.js",
  "engines": {
    "node": ">=22.0.0 <23.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:ts-node": "ts-node src/server.ts",
    "clean": "rimraf dist",
    "build": "npm run clean && tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "admin:create": "tsx src/scripts/createAdmin.ts",
    "admin:promote": "tsx src/scripts/promoteAdmin.ts",
    "super-admin:create": "tsx src/scripts/createAdmin.ts --role=super_admin",
    "super-admin:promote": "tsx src/scripts/promoteAdmin.ts --role=super_admin",
    "auth:check-otp-hash": "tsx src/scripts/checkLocalOtpHash.ts",
    "auth:set-test-otp": "tsx src/scripts/setLocalTestOtp.ts",
    "seed:payout-test": "tsx src/scripts/seedPayoutTestData.ts",
    "test:payout-logic": "tsx src/scripts/testPayoutLogic.ts",
    "db:indexes": "node dist/scripts/setupDatabaseIndexes.js",
    "db:normalize-hashes": "tsx src/scripts/normalizeOnChainHashes.ts",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [
    "arbitrum",
    "express",
    "mongodb",
    "api"
  ],
  "license": "UNLICENSED",
  "dependencies": {
    "@types/nodemailer": "^8.0.1",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.79.2",
    "compression": "^1.7.5",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "docx": "^9.7.1",
    "dotenv": "^16.4.7",
    "ethers": "^6.17.0",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "http-status-codes": "^2.3.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.9.5",
    "morgan": "^1.10.0",
    "node-cron": "^4.3.0",
    "nodemailer": "^9.0.3",
    "redis": "^6.0.0",
    "winston": "^3.17.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.10.5",
    "@types/node-cron": "^3.0.11",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
