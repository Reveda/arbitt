# Future multi-VPS edge load balancer template.
# Install this on a separate edge VPS or use the equivalent managed cloud LB.
# Replace the private IPs and domain before enabling it.

events {
    worker_connections 8192;
}

http {
    limit_req_zone $binary_remote_addr zone=api_per_ip:10m rate=20r/s;

    map $http_upgrade $connection_upgrade {
        default upgrade;
        "" close;
    }

    upstream application_servers {
        least_conn;

        # Each app server should expose its frontend Nginx on private port 8080.
        # Nginx removes an unhealthy server after repeated connection failures.
        server APP_SERVER_1_PRIVATE_IP:8080 max_fails=3 fail_timeout=15s;
        server APP_SERVER_2_PRIVATE_IP:8080 max_fails=3 fail_timeout=15s;
        # Add a third server before very high traffic:
        # server APP_SERVER_3_PRIVATE_IP:8080 max_fails=3 fail_timeout=15s;

        keepalive 128;
    }

    server {
        listen 80;
        server_name yourdomain.com www.yourdomain.com;
        return 301 https://$host$request_uri;
    }

    server {
        listen 443 ssl http2;
        server_name yourdomain.com www.yourdomain.com;

        ssl_certificate /etc/letsencrypt/live/yourdomain.com/fullchain.pem;
        ssl_certificate_key /etc/letsencrypt/live/yourdomain.com/privkey.pem;
        ssl_protocols TLSv1.2 TLSv1.3;
        add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;

        client_max_body_size 10m;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;

        location = /api/v1/health {
            proxy_pass http://application_servers;
            proxy_connect_timeout 3s;
            proxy_read_timeout 5s;
        }

        location /api/ {
            limit_req zone=api_per_ip burst=40 nodelay;
            proxy_pass http://application_servers;
            proxy_connect_timeout 5s;
            proxy_send_timeout 60s;
            proxy_read_timeout 90s;
        }

        location / {
            proxy_pass http://application_servers;
            proxy_connect_timeout 5s;
            proxy_read_timeout 90s;
        }
    }
}
